# PostgreSQL connection string
PG_DSN=postgres://loadgen:loadgen@localhost:5432/loadtest?sslmode=disable

# Workers
WORKERS=20

# Operation mix — must sum to 100
WRITE_PCT=35
READ_SIMPLE_PCT=15
READ_JOIN_PCT=20
UPDATE_PCT=15
DELETE_PCT=10
READ_IP_PCT=5

# Event payload size (KB)
MIN_PAYLOAD_KB=8
MAX_PAYLOAD_KB=16

# Schema
CREATE_INDEXES=false
RING_SIZE=10000
DELETE_BATCH_SIZE=50

# Runtime
THINK_TIME_MS=0
RUN_DURATION_SECS=0

# Observability
HOST_METRICS_PORT=9090
METRICS_PORT=9090
SUMMARY_INTERVAL_SECS=30
INDEX_STATS_INTERVAL_SECS=30
LOG_LEVEL=info
