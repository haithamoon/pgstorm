        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pgloadgen_bgwriter_buffers_checkpoint_total[$__rate_interval])", "legendFormat": "checkpoint buffers/sec", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pgloadgen_bgwriter_buffers_clean_total[$__rate_interval])", "legendFormat": "bgwriter buffers/sec", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pgloadgen_bgwriter_buffers_backend_total[$__rate_interval])", "legendFormat": "backend buffers/sec", "refId": "C" }
