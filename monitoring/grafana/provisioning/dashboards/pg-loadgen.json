        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le, op) (rate(pgloadgen_op_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{op}}", "refId": "A" }
      ]
