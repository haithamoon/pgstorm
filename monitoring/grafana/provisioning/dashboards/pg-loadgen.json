      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pgloadgen_ops_total{status=\"error\"}[$__rate_interval])", "legendFormat": "{{op}}", "refId": "A" }
      ]
