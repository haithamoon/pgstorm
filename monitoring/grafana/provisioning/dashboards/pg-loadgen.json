        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "pgloadgen_pool_idle_conns", "legendFormat": "idle", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "pgloadgen_pool_total_conns", "legendFormat": "total", "refId": "C" },
