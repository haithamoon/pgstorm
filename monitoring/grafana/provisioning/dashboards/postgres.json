        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (relname) (rate(pg_statio_user_tables_heap_blocks_read{datname=\"$database\"}[$__rate_interval]))", "legendFormat": "{{relname}} read", "refId": "B" }
