{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "PostgreSQL internals via postgres_exporter",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["postgres", "pg-loadgen"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource",
        "label": "Data source"
      },
      {
        "current": { "text": "loadtest", "value": "loadtest" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(pg_stat_database_xact_commit, datname)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "database",
        "options": [],
        "query": "label_values(pg_stat_database_xact_commit, datname)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Database"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PostgreSQL",
  "uid": "postgres-dashboard",
  "version": 1,
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Overview", "type": "row" },

    {
      "id": 1, "type": "stat", "title": "PostgreSQL Up",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "pg_up", "legendFormat": "", "refId": "A" }]
    },

    {
      "id": 2, "type": "stat", "title": "Active Connections",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(pg_stat_activity_count{datname=\"$database\", state=\"active\"})", "legendFormat": "", "refId": "A" }]
    },

    {
      "id": 3, "type": "stat", "title": "Transactions/sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_xact_commit{datname=\"$database\"}[$__rate_interval])", "legendFormat": "", "refId": "A" }]
    },

    {
      "id": 4, "type": "stat", "title": "Cache Hit Ratio",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_blks_hit{datname=\"$database\"}[$__rate_interval]) / (rate(pg_stat_database_blks_hit{datname=\"$database\"}[$__rate_interval]) + rate(pg_stat_database_blks_read{datname=\"$database\"}[$__rate_interval]) + 1) * 100", "legendFormat": "", "refId": "A" }]
    },

    {
      "id": 5, "type": "stat", "title": "Database Size",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "pg_database_size_bytes{datname=\"$database\"}", "legendFormat": "", "refId": "A" }]
    },

    {
      "id": 6, "type": "stat", "title": "Deadlocks",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(pg_stat_database_deadlocks{datname=\"$database\"}[$__rate_interval])", "legendFormat": "", "refId": "A" }]
    },

    {
      "id": 7, "type": "stat", "title": "Idle in Transaction",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(pg_stat_activity_count{datname=\"$database\", state=\"idle in transaction\"})", "legendFormat": "", "refId": "A" }]
    },

    {
      "id": 8, "type": "stat", "title": "Rollbacks/sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_xact_rollback{datname=\"$database\"}[$__rate_interval])", "legendFormat": "", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 110, "title": "Connections & Activity", "type": "row" },

    {
      "id": 9, "type": "timeseries", "title": "Connections by State",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 15, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "none" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (state) (pg_stat_activity_count{datname=\"$database\"})", "legendFormat": "{{state}}", "refId": "A" }
      ]
    },

    {
      "id": 10, "type": "timeseries", "title": "Max Active Transaction Duration",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 300 }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "pg_stat_activity_max_tx_duration{datname=\"$database\", state=\"active\"}", "legendFormat": "max tx duration", "refId": "A" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 120, "title": "Transactions", "type": "row" },

    {
      "id": 11, "type": "timeseries", "title": "Commits & Rollbacks/sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_xact_commit{datname=\"$database\"}[$__rate_interval])", "legendFormat": "commits/sec", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_xact_rollback{datname=\"$database\"}[$__rate_interval])", "legendFormat": "rollbacks/sec", "refId": "B" }
      ]
    },

    {
      "id": 12, "type": "timeseries", "title": "Temp Files & Temp Bytes",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "temp bytes" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "options": {
        "legend": { "calcs": ["max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_temp_files{datname=\"$database\"}[$__rate_interval])", "legendFormat": "temp files/sec", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_temp_bytes{datname=\"$database\"}[$__rate_interval])", "legendFormat": "temp bytes", "refId": "B" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 130, "title": "Tuple Operations (Database)", "type": "row" },

    {
      "id": 13, "type": "timeseries", "title": "Row Writes/sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_tup_inserted{datname=\"$database\"}[$__rate_interval])", "legendFormat": "inserts/sec", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_tup_updated{datname=\"$database\"}[$__rate_interval])", "legendFormat": "updates/sec", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_tup_deleted{datname=\"$database\"}[$__rate_interval])", "legendFormat": "deletes/sec", "refId": "C" }
      ]
    },

    {
      "id": 14, "type": "timeseries", "title": "Row Reads/sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_tup_returned{datname=\"$database\"}[$__rate_interval])", "legendFormat": "returned/sec", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_database_tup_fetched{datname=\"$database\"}[$__rate_interval])", "legendFormat": "fetched/sec", "refId": "B" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }, "id": 140, "title": "Per-Table Stats", "type": "row" },

    {
      "id": 15, "type": "timeseries", "title": "Inserts/sec per Table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
