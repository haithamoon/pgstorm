        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_user_tables_n_tup_ins{datname=\"$database\"}[$__rate_interval])", "legendFormat": "{{relname}}", "refId": "A" }
      ]
    },

    {
      "id": 16, "type": "timeseries", "title": "Updates/sec per Table (incl. HOT)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_user_tables_n_tup_upd{datname=\"$database\"}[$__rate_interval])", "legendFormat": "{{relname}} upd", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(pg_stat_user_tables_n_tup_hot_upd{datname=\"$database\"}[$__rate_interval])", "legendFormat": "{{relname}} HOT upd", "refId": "B" }
      ]
    },

    {
      "id": 17, "type": "timeseries", "title": "Deletes/sec per Table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }, "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
